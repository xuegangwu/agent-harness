# Agent Harness 学习项目 - 环境配置
# 复制为 .env 后填入你的 API Key

# ===== Kimi (Moonshot) =====
# 获取地址: https://platform.moonshot.cn/
OPENAI_API_BASE_KIMI=https://api.moonshot.cn/v1/chat/completions
OPENAI_API_KEY_KIMI=填入你的Kimi API Key

# ===== MiniMax =====
# 获取地址: https://www.minimaxi.com/platform
OPENAI_API_BASE_MINIMAX=https://api.minimax.chat/v1/chat/completions
OPENAI_API_KEY_MINIMAX=填入你的MiniMax API Key

# ===== 当前使用的模型 =====
# Kimi: moonshot-v1-8k / moonshot-v1-32k / moonshot-v1-128k
# MiniMax: MiniMax-Text-01 / abab6.5s-chat
CURRENT_MODEL=moonshot-v1-8k
CURRENT_API_BASE=https://api.moonshot.cn/v1/chat/completions
CURRENT_API_KEY=填入你的Kimi API Key
